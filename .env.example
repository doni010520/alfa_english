# Copie este arquivo para .env.local e preencha com suas credenciais

# URL do seu projeto Supabase (encontre em Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Chave anônima do Supabase (encontre em Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL do backend do assistente IA (FastAPI)
VITE_ASSISTANT_API_URL=http://localhost:8000

# ============================================
# Backend (criar arquivo backend/.env separado)
# ============================================
# OPENAI_API_KEY=sk-...
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGci...
